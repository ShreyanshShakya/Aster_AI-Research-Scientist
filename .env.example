# Server
PORT=3000
DATA_DIR=data

# Optional: enables OpenAI-backed research synthesis. Leave blank for offline-demo mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Optional: retrieve public paper metadata from Semantic Scholar before synthesis.
PAPER_SEARCH_ENABLED=true
SEMANTIC_SCHOLAR_API_KEY=
# Set false to disable the automatic fallback provider.
OPENALEX_SEARCH_ENABLED=true

# Optional: trusted server-side worker registry. Never expose tokens or this value to the browser.
# Example:
# WORKER_CONFIG_JSON=[{"type":"remote","id":"gpu-lab-02","endpoint":"https://worker.example/execute","capabilities":["cpu","gpu"],"slots":1,"timeoutMs":1800000,"token":"replace-me"}]
# DMLF bridge example. The bridge submits work to its gRPC Cluster Manager and
# exposes durable DMLF job state at GET /jobs/:jobId.
# WORKER_CONFIG_JSON=[{"type":"dmlf","id":"dmlf-cluster","endpoint":"http://127.0.0.1:8002/execute","capabilities":["cpu"],"slots":1,"timeoutMs":1800000}]
WORKER_CONFIG_JSON=
